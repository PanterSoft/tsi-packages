{
  "name": "python",
  "version": "3.12.2",
  "description": "Python programming language",
  "source": {
    "type": "tarball",
    "url": "https://www.python.org/ftp/python/3.12.2/Python-3.12.2.tgz"
  },
  "dependencies": [
    "openssl",
    "zlib",
    "sqlite",
    "libffi",
    "libuuid"
  ],
  "build_dependencies": [
    "make",
    "coreutils"
  ],
  "build_system": "autotools",
  "configure_args": [
    "--enable-optimizations",
    "--with-openssl=$TSI_INSTALL_DIR",
    "--enable-shared"
  ],
  "configure_args_darwin": [
    "--with-openssl=$TSI_INSTALL_DIR",
    "--enable-shared"
  ],
  "env": {
    "LDFLAGS": "-L$TSI_INSTALL_DIR/lib -lintl"
  },
  "env_darwin": {
    "ac_cv_func_uuid_generate_time_safe": "no",
    "ac_cv_lib_uuid_uuid_generate_time_safe": "no"
  }
}