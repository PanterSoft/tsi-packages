{
  "name": "berkeley-db",
  "version": "18.1.40",
  "description": "Berkeley DB embedded database library",
  "source": {
    "type": "tarball",
    "url": "https://download.oracle.com/berkeley-db/db-18.1.40.tar.gz"
  },
  "dependencies": [],
  "build_dependencies": [
    "make",
    "coreutils"
  ],
  "build_system": "custom",
  "build_commands": [
    "cd build_unix && ../dist/configure --prefix=$TSI_INSTALL_DIR --enable-cxx --enable-dbm --disable-sql",
    "cd build_unix && make",
    "cd build_unix && make install_lib install_include install_utilities"
  ],
  "env": {}
}